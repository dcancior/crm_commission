<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_mechanic_commission_wizard_form" model="ir.ui.view">
        <field name="name">mechanic.commission.wizard.form</field>
        <field name="model">mechanic.commission.wizard</field>
        <field name="arch" type="xml">
            <form string="Reporte de Comisiones">
                <sheet>
                    <group col="4">
                        <field name="employee_id" 
                            options="{'no_create': True}"
                            domain="[('job_id.name', 'ilike', 'Mecánic'), '|', ('active', '=', True), ('active', '=', False)]"
                            context="{'show_mechanics': True}"/>
                        <field name="month"/>
                        <field name="year"/>
                        <field name="report_paid_filter"/>
                        <field name="allowed_employee_ids" invisible="1"/>
                    </group>

                    <notebook>
                        <page string="Líneas de comisión">
                            <field name="line_ids" readonly="0">
                                <tree editable="bottom" create="0" delete="0">
                                    <field name="wizard_id" invisible="1"/>
                                    <field name="commission_entry_id" invisible="1"/>
                                    <field name="invoice_name" readonly="1"/>
                                    <field name="invoice_date" readonly="1"/>
                                    <field name="product_name" readonly="1"/>
                                    <field name="quantity" readonly="1"/>
                                    <field name="subtotal_customer" readonly="1" sum="Total Venta"/>
                                    <field name="porcentaje_comision" readonly="1" widget="float_factor" options="{'factor': 0.01}"/>
                                    <field name="commission_amount" readonly="1" sum="Total Comisión"/>
                                    <field name="is_paid"/>
                                    <field name="pago_comision"/>
                                    <field name="paid_date" readonly="1"/>
                                    <field name="paid_by" readonly="1"/>
                                </tree>
                            </field>
                            <group class="oe_subtotal_footer">
                                <field name="services_count"/>
                                <field name="amount_invoiced"/>
                                <field name="currency_id" invisible="1"/>
                            </group>
                        </page>
                    </notebook>

                    <footer>
                        <button string="Guardar cambios" 
                                type="object"
                                name="action_save_lines"
                                class="btn-primary"/>
                        <button string="Marcar todas como pagadas"
                                type="object"
                                name="action_mark_all_paid"
                                class="btn-secondary"/>
                        <button string="Imprimir PDF"
                                type="object"
                                name="action_print_pdf"
                                class="btn-secondary"/>
                        <button string="Cerrar"
                                special="cancel"
                                class="btn-secondary"/>
                    </footer>
                </sheet>
            </form>
        </field>
    </record>

    <record id="view_mechanic_commission_mass_pay_wizard_form" model="ir.ui.view">
        <field name="name">mechanic.commission.mass.pay.wizard.form</field>
        <field name="model">mechanic.commission.mass.pay.wizard</field>
        <field name="arch" type="xml">
            <form string="Marcar comisiones como pagadas">
                <sheet>
                    <group>
                        <field name="pago_comision"/>
                        <field name="paid_date"/>
                        <field name="pay_note"/>
                    </group>
                </sheet>
                <footer>
                    <button string="Confirmar" name="action_confirm" type="object" class="btn-primary"/>
                    <button string="Cancelar" class="btn-secondary" special="cancel"/>
                </footer>
            </form>
        </field>
    </record>

    <!-- Acción del menú -->
    <record id="action_mechanic_commission_wizard" model="ir.actions.act_window">
        <field name="name">Reporte de Comisiones (Mecánicos)</field>
        <field name="res_model">mechanic.commission.wizard</field>
        <field name="view_mode">form</field>
        <field name="target">new</field>
    </record>

    <!-- Menú -->
    <menuitem id="menu_mechanic_commission_root"
              name="Comisiones Mecánicos"
              sequence="100"
              groups="crm_commission.group_mechanic_commission_view"/>

    <menuitem id="menu_mechanic_commission_report"
              name="Reporte mensual"
              parent="menu_mechanic_commission_root"
              action="action_mechanic_commission_wizard"
              sequence="10"/>
</odoo>