<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_mechanic_commission_wizard_form" model="ir.ui.view">
        <field name="name">mechanic.commission.wizard.form</field>
        <field name="model">mechanic.commission.wizard</field>
        <field name="arch" type="xml">
            <form string="Reporte de comisiones de mecánicos (mensual)">
                <sheet>
                    <!-- Filtros -->
                    <group col="4">
                        <field name="employee_id"
                               options="{'no_create_edit': True}"
                               domain="[('active','=',True), ('job_id.name','ilike','Mecán')]"/>
                        <field name="month"/>
                        <field name="year"/>
                        <field name="report_paid_filter"/>
                    </group>

                    <!-- KPIs -->
                    <group col="4">
                        <field name="services_count" readonly="1"/>
                        <field name="amount_invoiced" readonly="1" sum="Total Facturado"/>
                        <field name="total_commission" readonly="1" sum="Total Comisiones"/>
                        <field name="payout_total" readonly="1" sum="Total Pagado"/>
                    </group>

                    <!-- Detalle -->
                    <notebook>
                        <page string="Detalle de líneas facturadas">
                            <field name="line_ids" nolabel="1"
                                   context="{'no_open': 1}"
                                   options="{'no_create': True}">
                                <tree editable="bottom" create="0" edit="0" delete="0">
                                    <!-- columnas -->
                                    <field name="invoice_name" readonly="1"/>
                                    <field name="invoice_date" readonly="1"/>
                                    <field name="product_name" readonly="1"/>
                                    <field name="price_unit" readonly="1" sum="Total Precio"/>
                                    <field name="quantity" readonly="1"/>
                                    <field name="price_subtotal" readonly="1" sum="Total"/>
                                    <field name="porcentaje_comision" readonly="1"/>
                                    <field name="commission_amount" readonly="1" sum="Total Comisión"/>
                                    <field name="payment_state" readonly="1"/>
                                    <field name="is_paid"/>
                                    <field name="pago_comision" attrs="{'readonly': [('is_paid', '=', False)]}"/>
                                    <field name="paid_date" readonly="1"/>
                                    <field name="paid_by" readonly="1"/>
                                </tree>

                                <form string="Detalle de comisión">
                                    <group>
                                        <!-- Campos técnicos -->
                                        <field name="wizard_id" invisible="1"/>
                                        <field name="commission_entry_id" invisible="1"/>
                                    </group>
                                    
                                    <group string="Información de Factura">
                                        <field name="invoice_name" readonly="1"/>
                                        <field name="invoice_date" readonly="1"/>
                                        <field name="payment_state" readonly="1"/>
                                    </group>
                                    
                                    <group string="Detalles del Servicio">
                                        <field name="product_name" readonly="1"/>
                                        <field name="price_unit" readonly="1"/>
                                        <field name="quantity" readonly="1"/>
                                        <field name="price_subtotal" readonly="1"/>
                                        <field name="porcentaje_comision" readonly="1"/>
                                        <field name="commission_amount" readonly="1"/>
                                    </group>
                                    
                                    <group string="Estado de Pago">
                                        <field name="is_paid"/>
                                        <field name="pago_comision" 
                                               attrs="{'readonly': [('is_paid', '=', False)]}"/>
                                        <field name="paid_date" readonly="1"/>
                                        <field name="paid_by" readonly="1"/>
                                    </group>
                                </form>
                            </field>
                        </page>
                    </notebook>
                </sheet>

                <footer>
                    <button name="action_save_lines" 
                            type="object" 
                            string="Guardar cambios" 
                            class="oe_highlight"/>
                    <button name="action_mark_all_paid" 
                            type="object" 
                            string="Marcar todas como pagadas" 
                            class="oe_highlight"/>
                    <button string="Cerrar" 
                            special="cancel"/>
                    <button name="action_print_pdf" 
                            type="object" 
                            string="Descargar PDF"/>
                </footer>
            </form>
        </field>
    </record>

    <!-- Acción del Wizard -->
    <record id="action_mechanic_commission_wizard" model="ir.actions.act_window">
        <field name="name">Reporte de Comisiones (Mecánicos)</field>
        <field name="res_model">mechanic.commission.wizard</field>
        <field name="view_mode">form</field>
        <field name="target">new</field>
    </record>

    <!-- Menú principal -->
    <menuitem id="menu_mechanic_commission_root"
              name="Comisiones Mecánicos"
              sequence="100"
              groups="crm_commission.group_mechanic_commission_view"
              web_icon="crm_commission,static/description/icon_mechanic.svg"/>

    <!-- Submenú para el reporte -->
    <menuitem id="menu_mechanic_commission_report"
              name="Reporte mensual"
              parent="menu_mechanic_commission_root"
              action="action_mechanic_commission_wizard"
              sequence="10"
              groups="crm_commission.group_mechanic_commission_view"/>

    <!-- Wizard de pago masivo -->
    <record id="view_mechanic_commission_mass_pay_wizard_form" model="ir.ui.view">
        <field name="name">mechanic.commission.mass.pay.wizard.form</field>
        <field name="model">mechanic.commission.mass.pay.wizard</field>
        <field name="arch" type="xml">
            <form string="Marcar como pagadas">
                <group>
                    <field name="pago_comision" required="1"/>
                    <field name="paid_date"/>
                    <field name="pay_note"/>
                </group>
                <group>
                    <field name="entry_ids" 
                           widget="many2many_tags" 
                           options="{'no_open': True, 'no_create': True}"/>
                </group>
                <footer>
                    <button name="action_confirm" 
                            type="object" 
                            string="Aplicar" 
                            class="oe_highlight"/>
                    <button string="Cancelar" 
                            special="cancel"/>
                </footer>
            </form>
        </field>
    </record>
</odoo>