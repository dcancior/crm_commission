<odoo>
  <!-- Vista heredada para sale.order: se apoya en la vista oficial de ventas -->
  <record id="view_order_form_mechanic_line" model="ir.ui.view">
    <field name="name">sale.order.form.mechanic.line</field>
    <field name="model">sale.order</field>
    <field name="inherit_id" ref="sale.view_order_form"/>

    <field name="arch" type="xml">

      <!--
      OBJETIVO GENERAL:
      Añadir a las líneas de pedido (sale.order.line) campos relacionados con el “mecánico”
      y reglas de visualización/alerta. La lógica se activa sólo en líneas de tipo servicio.
      -->

      <!-- 1) Inyección de flags en el TREE -->
      <xpath expr="//field[@name='order_line']/tree" position="inside">
        <field name="display_mechanic_fields" invisible="1"/>
        <field name="product_type" invisible="1"/>
        <field name="mechanic_is_placeholder" invisible="1"/>
        <!-- NUEVO: bandera para exentar líneas cuyo producto empiece con 'PAQ' -->
        <field name="mechanic_exempt" invisible="1"/>
      </xpath>

      <!-- 2) Decoración de fila (warning) con exención por 'PAQ*' -->
      <xpath expr="//field[@name='order_line']/tree" position="attributes">
        <attribute name="decoration-warning">
          (display_mechanic_fields) and (not mechanic_id or mechanic_is_placeholder) and (not mechanic_exempt)
        </attribute>
      </xpath>

      <!-- 3) Columna "Mecánico" antes del subtotal -->
      <xpath expr="//field[@name='order_line']/tree/field[@name='price_subtotal']" position="before">
          <field name="mechanic_id"
              string="Mecánico"
              optional="show"
              domain="[
                  ('active','=',True),
                  ('department_id.name', 'ilike', 'Mecánicos'),
                  ('company_id','=', company_id)
              ]"
              attrs="{'readonly':[('display_mechanic_fields','=',False)]}"/>
      </xpath>

      <!-- 4) Costo mecánico después del subtotal -->
      <xpath expr="//field[@name='order_line']/tree/field[@name='price_subtotal']" position="after">
        <field name="mechanic_cost_subtotal"
               optional="hide"
               attrs="{'invisible':[('display_mechanic_fields','=',False)]}"/>
      </xpath>

      <!-- 5) Inyección de flags en el FORM (grupo oculto) -->
      <xpath expr="//field[@name='order_line']/form" position="inside">
        <group invisible="1">
          <field name="display_mechanic_fields"/>
          <field name="product_type"/>
          <field name="mechanic_is_placeholder"/>
          <!-- NUEVO: misma bandera en el form -->
          <field name="mechanic_exempt"/>
        </group>
      </xpath>

      <!-- 6) Grupo visible “Mecánico” en el FORM -->
      <xpath expr="//field[@name='order_line']/form//group[1]" position="after">
          <group string="Mecánico">
              <field name="mechanic_id"
                  domain="[
                      ('active','=',True),
                      ('department_id.name', 'ilike', 'Mecánicos'),
                      ('company_id','=', parent.company_id)
                  ]"/>
              <field name="mechanic_hours_required" readonly="1"
                  attrs="{'invisible':[('display_mechanic_fields','=',False)]}"/>
              <field name="mechanic_cost_per_hour" readonly="1"
                  attrs="{'invisible':[('display_mechanic_fields','=',False)]}"/>
              <field name="mechanic_cost_subtotal" readonly="1"
                  attrs="{'invisible':[('display_mechanic_fields','=',False)]}"/>
          </group>
      </xpath>

      <!-- Banner visial sólo para grupo de comisiones-->
      <xpath expr="//sheet" position="before">
          <!-- Campo técnico (obligatorio para attrs) -->
          <field name="has_missing_mechanic" invisible="1"/>
          <div class="alert alert-danger"
              attrs="{'invisible': [('has_missing_mechanic', '=', False)]}"
              groups="crm_commission.group_mechanic_commission_view">

              ⚠ Esta orden fue confirmada sin mecánico. Debes asignarlo.

              <button name="action_open_set_mechanic_wizard"
                      type="object"
                      string="Asignar ahora"
                      class="btn btn-danger btn-sm ms-2"/>
          </div>
      </xpath>

    </field>
  </record>

  <!-- Filtro para órdenes con mecánico faltante -->
  <record id="view_sale_order_filter_mechanic" model="ir.ui.view">
    <field name="name">sale.order.search.mechanic</field>
    <field name="model">sale.order</field>
    <field name="inherit_id" ref="sale.view_sales_order_filter"/>
    <field name="arch" type="xml">
      <xpath expr="//search" position="inside">
        <group expand="0" string="Operación"> 
          <filter name="missing_mechanic"
              string="⚠ Sin mecánico"
              domain="[('has_missing_mechanic', '=', True), ('state', '=', 'sale')]"/>
          </group>
      </xpath>
    </field>
  </record>
</odoo>
