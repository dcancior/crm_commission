<odoo>
    <!-- Extensión existente: parámetros de servicio -->
    <record id="view_product_form_mechanic_fields" model="ir.ui.view">
        <field name="name">product.template.form.mechanic.fields</field>
        <field name="model">product.template</field>
        <field name="inherit_id" ref="product.product_template_form_view"/>
        <field name="arch" type="xml">
            <!-- Agrega el grupo sólo para productos tipo servicio -->
            <xpath expr="//field[@name='type']" position="after">
                <group string="Parámetros de servicio (mecánico)" attrs="{'invisible': [('type','!=','service')]}">
                    <field name="service_hours_required" invisible="1"/>
                    <field name="service_cost_per_hour" invisible="1"/>
                </group>
            </xpath>

            <!-- NUEVO: agregar 'porcentaje_comision' justo después de list_price -->
            <!-- NUEVO: agregar 'porcentaje_comision' justo después de list_price con etiqueta visible -->
            <!-- NUEVO: agregar 'porcentaje_comision' justo después de list_price en una nueva línea -->
            <xpath expr="//field[@name='list_price']" position="after">
                <newline/>
                <label for="porcentaje_comision"
                    string="Porcentaje"
                    attrs="{'invisible': [('type','!=','service')]}"/>
                <field name="porcentaje_comision"
                    widget="percentage"
                    nolabel="1"
                    attrs="{'invisible': [('type','!=','service')]}"/>
            </xpath>
        </field>
    </record>
</odoo>
