<odoo>
    <!-- Extensión existente: parámetros de servicio -->
    <record id="view_product_form_mechanic_fields" model="ir.ui.view">
        <field name="name">product.template.form.mechanic.fields</field>
        <field name="model">product.template</field>
        <field name="inherit_id" ref="product.product_template_form_view"/>
        <field name="arch" type="xml">
            <!-- Agrega el grupo sólo para productos tipo servicio -->
            <xpath expr="//field[@name='type']" position="after">
                <group string="Parámetros de servicio (mecánico)" attrs="{'invisible': [('type','!=','service')]}">
                    <field name="service_hours_required" invisible="1"/>
                    <field name="service_cost_per_hour" invisible="1"/>
                </group>
            </xpath>

            <!-- NUEVO: colocar 'Porcentaje' en una línea nueva debajo de list_price,
                con el campo porcentaje_comision a la derecha en la misma fila -->
            <xpath expr="//field[@name='list_price']" position="after">
                <group col="2" attrs="{'invisible': [('type','!=','service')]}">
                    <label for="porcentaje_comision" string="Porcentaje"/>
                    <field name="porcentaje_comision" widget="percentage" nolabel="1"/>
                </group>
            </xpath>
        </field>
    </record>
</odoo>
