<odoo>
    <record id="view_order_form_inherit_commission" model="ir.ui.view">
        <field name="name">sale.order.form.inherit.commission</field>
        <field name="model">sale.order</field>
        <field name="inherit_id" ref="sale.view_order_form"/>
        <field name="priority">99</field>
        <field name="arch" type="xml">
            <!-- Modificar líneas de orden -->
            <xpath expr="//field[@name='order_line']/tree//field[@name='product_id']" position="after">
                <field name="mechanic_id" 
                       optional="show"
                       attrs="{'column_invisible': [('parent.state', 'in', ('draft','sent'))],
                              'required': [('product_type', '=', 'service')]}"/>
                <field name="porcentaje_comision" 
                       optional="show"/>
                <field name="product_type" invisible="1"/>
            </xpath>

            <!-- Agregar campos en la forma -->
            <xpath expr="//field[@name='order_line']/form//field[@name='product_id']" position="after">
                <field name="mechanic_id" 
                       attrs="{'invisible': [('product_type', '!=', 'service')],
                              'required': [('product_type', '=', 'service')]}"/>
                <field name="porcentaje_comision"/>
                <field name="product_type" invisible="1"/>
            </xpath>
        </field>
    </record>
</odoo>